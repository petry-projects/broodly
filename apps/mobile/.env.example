# =============================================================================
# Broodly Mobile — Environment Variables
# =============================================================================
# Copy this file to .env and fill in values for your environment.
# For local development with the Firebase Emulator, the defaults below work
# out of the box — just run `pnpm firebase:emulator:start` from the repo root.
# =============================================================================

# --- Firebase Auth Emulator -------------------------------------------------
# Set to "true" to connect to the local Firebase Auth Emulator (port 9099).
# When true, no real Firebase credentials are needed.
EXPO_PUBLIC_FIREBASE_USE_EMULATOR=true

# Override the emulator host if running on a different address (e.g., Docker).
# Default: http://127.0.0.1:9099
# EXPO_PUBLIC_FIREBASE_EMULATOR_HOST=http://127.0.0.1:9099

# --- Firebase Web Config ----------------------------------------------------
# Required for production builds and when USE_EMULATOR is false.
# Find these values in Firebase Console → Project Settings → General → Web app.
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=broodly-dev
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# --- GraphQL API -------------------------------------------------------------
# URL of the Broodly GraphQL API server.
# For local dev, point to your local Go server.
EXPO_PUBLIC_API_URL=http://localhost:8080/graphql

# --- Test-Only Variables (used by Playwright / E2E tests) --------------------
# These are NOT used by the app at runtime. They configure test fixtures.
# FIREBASE_API_KEY=            # Firebase API key for test token generation
# TEST_USER_EMAIL=             # Email of a pre-created test user
# TEST_USER_PASSWORD=          # Password of the test user (emulator only)
